{
  "private": true,
  "name": "necto-monorepo",
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "changeset": "changeset",
    "test": "turbo run //#test:vitest",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "turbo run test:coverage",
    "test:visual": "turbo run test:visual",
    "build": "turbo run //#build:tsdown",
    "build:tsdown": "tsdown",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "postinstall": "lefthook install && playwright install",
    "clean": "rimraf --glob packages/**/node_modules packages/**/.turbo packages/**/dist packages/**/.dist node_modules .turbo dist .dist"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "csstype": "3.2.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "^2.31.0",
    "@codecov/rollup-plugin": "^2.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "commitlint": "^20.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "csstype": "3.2.3",
    "fast-glob": "^3.3.3",
    "lefthook": "^2.1.6",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsdown": "^0.12.9",
    "turbo": "^2.9.6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "yaml-lint": "^1.7.0"
  },
  "packageManager": "pnpm@10.33.2"
}
