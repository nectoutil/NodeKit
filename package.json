{
  "private": true,
  "name": "necto-monorepo",
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "changeset": "changeset",
    "test": "vitest run",
    "test:coverage": "turbo run test:coverage",
    "test:visual": "turbo run test:visual",
    "build": "turbo run //#build:tsdown",
    "build:tsdown": "tsdown",
    "lint": "set DEBUG=biome* && biome lint --write",
    "format": "set DEBUG=biome* && biome format --write",
    "postinstall": "lefthook install && echo '🚨 Corinvo CLI will be required soon! Install it now to keep developing smoothly. 🚀'",
    "clean": "find packages -type d \\( -name 'node_modules' -o -name '.turbo' -o -name 'dist' -o -name '.dist' \\) -prune -exec rm -rf '{}' + && rm -rf node_modules .turbo dist .dist"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.2",
      "csstype": "3.2.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0-beta.5",
    "@changesets/cli": "^2.31.0",
    "@codecov/rollup-plugin": "^2.0.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "commitlint": "^19.8.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "csstype": "3.2.3",
    "fast-glob": "^3.3.3",
    "lefthook": "^1.13.6",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.12.9",
    "turbo": "^2.4.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4",
    "yaml-lint": "^1.7.0"
  },
  "packageManager": "pnpm@10.33.0"
}
