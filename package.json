{
  "private": true,
  "name": "necto-monorepo",
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter './packages/**' --parallel run dev",
    "changeset": "changeset",
    "clean-publish": "node scripts/clean-publish.mjs",
    "test": "pnpm build && vp test run",
    "test:vitest": "vp test run",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "test:coverage": "pnpm --filter './packages/**' run test:coverage",
    "test:visual": "pnpm --filter './packages/**' run test:visual",
    "build": "pnpm --filter './packages/**' run build",
    "lint": "vp lint --fix",
    "format": "vp fmt",
    "prepare": "vp config",
    "postinstall": "playwright install",
    "clean": "rimraf --glob packages/**/node_modules packages/**/dist packages/**/.dist node_modules dist .dist"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3",
      "csstype": "3.2.3"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/lint": "^20.5.3",
    "@commitlint/load": "^20.5.3",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "commitlint": "^20.5.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "csstype": "3.2.3",
    "danger": "^13.0.8",
    "dedent": "^1.7.2",
    "fast-glob": "^3.3.3",
    "markdownlint": "^0.41.0",
    "markdownlint-cli": "^0.48.0",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite-plus": "^0.2.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "yaml-lint": "^1.7.0"
  },
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=24"
  }
}
