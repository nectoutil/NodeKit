{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["//#build:pkgs"],
      "outputs": ["coverage/**"]
    },
    "//#build:pkgs": {
      "inputs": ["packages/**/src/**", "packages/**/tsdown.config.ts", "tsdown.config.ts"],
      "outputs": ["packages/**/dist/**"],
      "env": ["CODECOV_TOKEN"]
    }
  }
}