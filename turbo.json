{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["//#build:tsdown"],
      "outputs": ["coverage/**"]
    },
    "//#build:tsdown": {
      "inputs": [
        "packages/**/src/**",
        "packages/**/tsdown.config.ts",
        "tsdown.config.ts"
      ],
      "outputs": ["packages/**/dist/**"],
      "env": ["CODECOV_TOKEN"]
    },
    "//#test:vitest": {
      "dependsOn": ["//#build:tsdown"],
      "inputs": [
        "packages/**/src/**",
        "packages/**/__tests__/**",
        "packages/**/vitest.config.*",
        "packages/**/vitest.setup.*",
        "vitest.config.*"
      ],
      "outputs": []
    }
  }
}
