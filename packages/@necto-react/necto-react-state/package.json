{
  "name": "@necto-react/state",
  "version": "0.2.1",
  "description": "React bindings for @necto/state.",
  "scripts": {
    "build": "tsdown --minify",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "dependencies": {
    "@necto/state": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^29.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsdown": "^0.12.7",
    "@vitest/coverage-istanbul": "^3.2.4"
  }
}
