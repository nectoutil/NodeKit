{
  "name": "@necto-react/components",
  "version": "3.2.0",
  "type": "module",
  "description": "Necto's standard library for providing utility components for React applications.",
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:all": "pnpm test:unit && pnpm test:visual",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto-react/necto-react-components"
  },
  "devDependencies": {
    "@emotion/jest": "^11.14.2",
    "@emotion/styled": "^11.14.1",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "axe-core": "^4.11.3",
    "clsx": "^2.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.4",
    "vitest-axe": "^1.0.0-pre.5"
  },
  "peerDependencies": {
    "@types/react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@necto-react/hooks": "workspace:*",
    "@necto/constants": "workspace:*",
    "@necto/dom": "workspace:*",
    "@necto/strings": "workspace:*"
  }
}
