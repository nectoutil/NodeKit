{
  "name": "@necto-react/popper",
  "version": "0.10.0",
  "type": "module",
  "description": "Necto's React library for positioning, popovers, tooltips, and floating elements.",
  "scripts": {
    "test": "vitest",
    "build": "tsup",
    "dev": "tsup ./src/index.ts --watch --minify --format esm,cjs,iife --dts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit.git"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "dependencies": {
    "@necto-react/components": "workspace:*",
    "@necto-react/hooks": "workspace:*",
    "@necto-react/state": "workspace:*",
    "@necto-react/types": "workspace:*",
    "@necto/dom": "workspace:*",
    "@necto/mergers": "workspace:*",
    "@necto/popper": "workspace:*",
    "@necto/types": "workspace:*",
    "defu": "^6.1.6"
  }
}
