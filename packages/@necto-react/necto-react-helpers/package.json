{
  "name": "@necto-react/helpers",
  "version": "2.6.16",
  "description": "Necto's library for providing global helpers React applications",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto-react/necto-react-helpers"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.12.7",
    "@vitest/coverage-istanbul": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "@necto-react/types": "workspace:*",
    "@necto/dom": "workspace:*",
    "@necto/platform": "workspace:*",
    "std-env": "^3.10.0"
  }
}
