{
  "name": "@necto-react/types",
  "version": "2.4.1",
  "description": "Necto's shared TypeScript type definitions for React packages.",
  "scripts": {
    "build": "tsdown --minify"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsdown": "^0.21.9"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto-react/necto-react-types"
  }
}
