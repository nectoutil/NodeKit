{
  "name": "@necto-react/hooks",
  "version": "2.16.4",
  "type": "module",
  "description": "Necto's standard library for providing utility hooks for React applications.",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto-react/necto-react-hooks"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^3.2.4",
    "jsdom": "^26.1.0",
    "tsdown": "^0.12.7"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "@necto-react/helpers": "workspace:*",
    "@necto-react/types": "workspace:*",
    "@necto/dom": "workspace:*",
    "@necto/id": "workspace:*",
    "@necto/mergers": "workspace:*",
    "@necto/platform": "workspace:*",
    "@necto/strings": "workspace:*",
    "@necto/types": "workspace:*",
    "defu": "^6.1.7",
    "react-aria": "^3.39.0",
    "std-env": "^3.10.0"
  }
}
