{
  "name": "@necto-react/hooks",
  "version": "2.19.2",
  "type": "module",
  "description": "Necto's standard library for providing utility hooks for React applications.",
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto-react/necto-react-hooks"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "axe-core": "^4.11.4",
    "playwright": "^1.59.1",
    "tsdown": "^0.21.10",
    "vitest-axe": "^1.0.0-pre.5"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@necto-react/types": "workspace:*",
    "@necto/dom": "workspace:*",
    "@necto/id": "workspace:*",
    "@necto/mergers": "workspace:*",
    "@necto/platform": "workspace:*",
    "@necto/strings": "workspace:*",
    "@necto/types": "workspace:*",
    "defu": "^6.1.7",
    "std-env": "^4.1.0"
  }
}
