{
  "name": "@necto/crypto",
  "version": "1.0.1",
  "type": "module",
  "description": "Necto's cryptographic utilities.",
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "devDependencies": {
    "@peculiar/webcrypto": "^1.5.0",
    "@stablelib/aes": "^2.0.1",
    "@stablelib/base64": "^2.0.1",
    "@stablelib/bytes": "^2.0.1",
    "@stablelib/chacha20poly1305": "^2.0.1",
    "@stablelib/ed25519": "^2.1.0",
    "@stablelib/hex": "^2.0.1",
    "@stablelib/hmac": "^2.0.1",
    "@stablelib/random": "^2.0.1",
    "@stablelib/sha256": "^2.0.1",
    "@stablelib/sha512": "^2.0.1",
    "@stablelib/x25519": "^2.0.1",
    "@stablelib/xchacha20poly1305": "^2.0.1",
    "@types/node": "^22.19.17",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-istanbul": "^4.1.5",
    "buffer": "^6.0.3",
    "fast-check": "^4.7.0",
    "node-forge": "^1.4.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-crypto"
  }
}
