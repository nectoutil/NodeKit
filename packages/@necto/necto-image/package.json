{
  "name": "@necto/image",
  "version": "1.0.23",
  "description": "Framework-agnostic image transformation utilities for CDN providers",
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-image"
  },
  "dependencies": {
    "@necto/dom": "workspace:*",
    "@necto/url": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
