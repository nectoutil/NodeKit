{
  "name": "@necto/id",
  "version": "1.6.8",
  "type": "module",
  "description": "Necto's library for generating algorithmic ID's based on specified parameters.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap",
    "build:watch": "vp pack --format esm,cjs --dts --sourcemap --watch",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "necto",
    "corinvo",
    "nectoutil"
  ],
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/randombytes": "^2.0.3",
    "@vitest/coverage-istanbul": "^4.1.10"
  },
  "dependencies": {
    "@necto/assert": "workspace:*",
    "@necto/crypto": "workspace:*",
    "@necto/constants": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-id"
  }
}
