{
  "name": "@necto/id",
  "version": "1.6.6",
  "type": "module",
  "description": "Necto's library for generating algorithmic ID's based on specified parameters.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --minify",
    "build:watch": "tsup --watch"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "necto",
    "corinvo",
    "nectoutil"
  ],
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/randombytes": "^2.0.3",
    "tsup": "^8.4.0"
  },
  "dependencies": {
    "@necto/assert": "workspace:*",
    "@necto/crypto": "workspace:*",
    "@necto/constants": "workspace:*"
  }
}
