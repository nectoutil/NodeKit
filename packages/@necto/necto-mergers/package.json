{
  "name": "@necto/mergers",
  "version": "1.5.3",
  "description": "Necto's library providing object and array merging utilities.",
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [],
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "catalog:",
    "react": "catalog:",
    "@vitest/coverage-istanbul": "^4.1.10"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-mergers"
  }
}
