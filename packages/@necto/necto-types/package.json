{
  "name": "@necto/types",
  "version": "1.3.1",
  "description": "Necto's universal types library",
  "type": "module",
  "scripts": {
    "build": "tsdown --minify"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.12.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-types"
  }
}
