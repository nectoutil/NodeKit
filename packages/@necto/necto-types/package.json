{
  "name": "@necto/types",
  "version": "1.4.1",
  "description": "Necto's universal types library",
  "type": "module",
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap"
  },
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-types"
  }
}
