{
  "name": "@necto/types",
  "version": "1.3.1",
  "description": "Necto's universal types library",
  "type": "module",
  "scripts": {
    "build": "tsup --minify"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
