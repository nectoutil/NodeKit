{
  "name": "@necto/constants",
  "version": "1.4.5",
  "description": "Necto's library defining common constant values for programs.",
  "scripts": {
    "build": "tsdown --dts",
    "build:watch": "tsdown --watch"
  },
  "keywords": [
    "necto",
    "corinvo",
    "nectoutil"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.21.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-constants"
  }
}
