{
  "name": "@necto/constants",
  "version": "2.0.0",
  "description": "Necto's library defining common constant values for programs.",
  "scripts": {
    "build": "tsdown --dts",
    "build:watch": "tsdown --watch"
  },
  "keywords": [
    "necto",
    "corinvo",
    "nectoutil"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "html-tags": "^5.1.0",
    "svg-tag-names": "^3.0.1",
    "css-color-names": "^1.0.1",
    "aria-attributes": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "html-void-elements": "^3.0.0",
    "html-element-attributes": "^3.5.0",
    "svg-element-attributes": "^2.1.0",
    "tsdown": "^0.12.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-constants"
  }
}
