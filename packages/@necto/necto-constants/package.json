{
  "name": "@necto/constants",
  "version": "1.4.5",
  "description": "Necto's library defining common constant values for programs.",
  "scripts": {
    "build": "tsup --dts",
    "build:watch": "tsup --watch"
  },
  "keywords": [
    "necto",
    "corinvo",
    "nectoutil"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
