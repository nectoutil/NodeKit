{
  "name": "@necto/file",
  "version": "1.0.0",
  "type": "module",
  "description": "File type detection utilities for Necto",
  "scripts": {
    "build": "tsdown --minify",
    "dev": "tsdown --watch"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/sax": "^1.2.7",
    "tsdown": "^0.12.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "sax": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-file"
  }
}
