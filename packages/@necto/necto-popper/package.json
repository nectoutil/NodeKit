{
  "name": "@necto/popper",
  "version": "0.5.9",
  "description": "Necto's library for providing positioning and popover utilities.",
  "scripts": {
    "test": "vitest",
    "build": "tsdown --minify",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsdown": "^0.12.7",
    "@vitest/coverage-istanbul": "^3.2.4"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@necto/constants": "workspace:*",
    "@necto/types": "workspace:*",
    "@necto/dom": "workspace:*"
  }
}
