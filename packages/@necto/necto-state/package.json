{
  "name": "@necto/state",
  "version": "0.0.4",
  "description": "Necto's atomic state management library.",
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.10"
  }
}
