{
  "name": "@necto/dom",
  "version": "1.11.3",
  "description": "Necto's library for providing helpers and tools to interact with the DOM.",
  "scripts": {
    "build": "vp pack --format esm,cjs --dts --minify --sourcemap",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "author": "Corinvo OSS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nectoutil/NodeKit",
    "directory": "packages/@necto/necto-dom"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@vitest/coverage-istanbul": "^4.1.10",
    "jsdom-testing-mocks": "^1.16.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@necto/constants": "workspace:*",
    "@necto/platform": "workspace:*",
    "@necto/types": "workspace:*"
  }
}
